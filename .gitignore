# ==========================================
# 1. Données (Dataset HAM10000) - CRITIQUE
# ==========================================
# Ne JAMAIS pousser les données brutes ou traitées sur Git
data/raw/
data/processed/
*.csv
*.zip

# ==========================================
# 2. Modèles d'IA Sauvegardés
# ==========================================
# Les poids des modèles sont trop lourds pour Git
models/*.h5
models/*.keras
models/*.pkl
models/*.joblib

# ==========================================
# 3. Sécurité & Configuration
# ==========================================
# Fichiers contenant des mots de passe, clés JWT ou URI de Base de données
.env
.env.local
.env.*.local
# (Note : Le fichier .env.example DOIT être versionné, donc on ne le met pas ici)

# ==========================================
# 4. Environnement Python & Jupyter
# ==========================================
# Environnements virtuels
venv/
env/
.venv/

# Cache et fichiers compilés
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# ==========================================
# 5. Logs & Sorties (Outputs)
# ==========================================
# Dossier des logs d'entraînement (TensorBoard, etc.)
logs/
tensorboard_logs/

# ==========================================
# 6. Frontend (React / Vite)
# ==========================================
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 7. Système et Éditeurs de Code (IDE)
# ==========================================
# Fichiers macOS
.DS_Store

# Fichiers VS Code / PyCharm
.vscode/
.idea/
*.swp